{% extends '@PrestaShop/Admin/layout.html.twig' %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('themes/new-theme/public/product_catalog.css') }}" type="text/css" media="all">
{% endblock %}

{% block content %}
  {% block products_listing %}
    {{ include('@PrestaShop/Admin/Sell/Catalog/Product/Grid/grid_panel.html.twig', {grid: productGrid}) }}
