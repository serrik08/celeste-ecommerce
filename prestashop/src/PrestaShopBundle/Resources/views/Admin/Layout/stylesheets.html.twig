{% endif %}
<link rel="stylesheet" href="{{ asset('jquery/plugins/fancybox/jquery.fancybox.css', 'front_js') }}" media="all">
<link rel="stylesheet" href="{{ asset('jquery/plugins/chosen/jquery.chosen.css', 'front_js') }}" media="all">
