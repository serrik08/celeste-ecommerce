{% form_theme titleForm '@PrestaShop/Admin/TwigTemplateForm/prestashop_ui_kit.html.twig' %}

{% block title_form %}
  {{ form_start(titleForm) }}
    <div class="card">
      <h3 class="card-header">
        <i class="material-icons">man</i>
        {{ 'Titles'|trans({}, 'Admin.Shopparameters.Feature') }}
      </h3>
      <div class="card-body">
        <div class="form-wrapper">
          {{ form_widget(titleForm) }}
        </div>
      </div>
      <div class="card-footer">
        <a href="{{ path('admin_title_index') }}" class="btn btn-outline-secondary">
          {{ 'Cancel'|trans({}, 'Admin.Actions') }}
        </a>
        <button class="btn btn-primary float-right" id="save-button">
          {{ 'Save'|trans({}, 'Admin.Actions') }}
        </button>
      </div>
    </div>
  {{ form_end(titleForm) }}
{% endblock %}
