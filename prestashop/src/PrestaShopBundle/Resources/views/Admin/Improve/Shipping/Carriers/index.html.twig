{% extends '@PrestaShop/Admin/layout.html.twig' %}
{% trans_default_domain 'Admin.Shipping.Feature' %}

{% block content %}
  {% block carrier_showcase_card %}
    {{ include('@PrestaShop/Admin/Improve/Shipping/Carriers/Blocks/showcase_card.html.twig') }}
  {% endblock %}

  {{ include('@PrestaShop/Admin/Improve/Shipping/Carriers/Blocks/information_block.html.twig') }}
  {{ include('@PrestaShop/Admin/Common/Grid/grid_panel.html.twig', {grid: carrierGrid}) }}

  {# Recommended modules will be attached to here. #}
  <div class="row">
    <div class="col"></div>
  </div>
{% endblock %}

{% block javascripts %}
  {{ parent() }}

  <script src="{{ asset('themes/new-theme/public/carrier.bundle.js') }}"></script>
  <script src="{{ asset('themes/default/js/bundle/pagination.js') }}"></script>
{% endblock %}
