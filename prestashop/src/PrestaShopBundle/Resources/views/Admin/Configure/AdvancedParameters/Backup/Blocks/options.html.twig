{% trans_default_domain 'Admin.Advparameters.Feature' %}
{% form_theme backupForm '@PrestaShop/Admin/TwigTemplateForm/prestashop_ui_kit.html.twig' %}

{% block backup_options_card %}
  {{ form_start(backupForm) }}
  <div class="card">
    <h3 class="card-header">
      <i class="material-icons">settings</i> {{ 'Backup options'|trans }}
    </h3>
    <div class="card-body">
      <div class="form-wrapper">
        {{ form_widget(backupForm) }}
      </div>
    </div>
    <div class="card-footer">
      <div class="d-flex justify-content-end">
        <button class="btn btn-primary">{{ 'Save'|trans({}, 'Admin.Actions') }}</button>
      </div>
    </div>
  </div>
  {{ form_end(backupForm) }}
{% endblock %}
