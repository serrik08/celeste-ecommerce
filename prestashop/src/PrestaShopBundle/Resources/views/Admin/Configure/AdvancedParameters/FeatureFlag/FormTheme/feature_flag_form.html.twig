{% block feature_flag_row %}
  <div class="form-group row feature_flag-widget">
    <div class="form-control-label">
      {{ form_label(form) }}
    </div>
    <div class="col-sm input-container">
      {{ form_widget(form) }}
    </div>
  </div>
{% endblock %}

{% block feature_flag_label %}
  <label for="{{ id }}">{{ label }}</label>
  <div>
    <ul class="list-inline small form-text">
      {% for type in types %}
        <li class="list-inline-item {% if type == used_type %}font-weight-bold{% endif %}">{{ type }}</li>
      {% endfor %}
    </ul>
  </div>
{% endblock %}

{% block feature_flag_widget %}
  {{ block('switch_widget') }}
  {% if forced_by_env %}
    <div class="small form-text font-weight-bold">{{ 'This FeatureFlag is forced by Env.'|trans({}, 'Admin.Advparameters.Help') }}</div>
  {% endif %}
{% endblock feature_flag_widget %}
