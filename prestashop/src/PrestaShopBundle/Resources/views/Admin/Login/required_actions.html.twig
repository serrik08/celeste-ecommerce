{% extends '@PrestaShop/Admin/Layout/login_layout.html.twig' %}

{% block content %}
  <div class="alert alert-warning d-print-none" role="alert">
    <p>{{ 'For security reasons, you cannot connect to the back office until you have:'|trans({}, 'Admin.Login.Notification') }}</p>
    <ul class="alert-text">
      {% for requiredAction in requiredActions %}
        <li>{{ requiredAction|raw_purified }}</li>
      {% endfor %}
    </ul>
  </div>
{% endblock %}
