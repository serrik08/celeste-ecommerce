<button id="{{ '%s_grid_bulk_action_%s'|format(grid.id, action.id) }}"
        data-categories-delete-url="{{ path(action.options.categories_bulk_delete_route) }}"
        class="dropdown-item js-delete-categories-bulk-action"
        type="button"
>
  {% if action.icon is not empty %}
    <i class="material-icons">{{ action.icon }}</i>
  {% endif %}
  {{ action.name }}
</button>
