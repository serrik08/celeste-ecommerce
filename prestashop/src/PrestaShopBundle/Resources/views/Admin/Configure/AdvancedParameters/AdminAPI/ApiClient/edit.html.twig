{% extends '@PrestaShop/Admin/Configure/AdvancedParameters/AdminAPI/ApiClient/form.html.twig' %}

{% block form_submit_buttons %}
  {# Regenerate button is only shown for internal API clients (identified via external_issuer field being null) #}
  {% if apiClientForm.vars.value.external_issuer|default(null) is null %}
    <a
      class="btn btn-primary generate-client-secret"
      href="{{ path('admin_api_clients_regenerate_secret', {apiClientId: app.request.get('apiClientId')}) }}"
      data-confirm-title="{{ 'Regenerate client secret?'|trans({}, 'Admin.Advparameters.Feature') }}"
      data-confirm-message="{{ 'If you regenerate your client secret, your former secret will become obsolete.'|trans({}, 'Admin.Advparameters.Feature') }}"
      data-confirm-button-label= "{{ 'Regenerate client secret'|trans({}, 'Admin.Advparameters.Feature') }}"
      data-close-button-label= "{{ 'Cancel'|trans({}, 'Admin.Actions') }}"
    >
      {{ 'Regenerate client secret'|trans({}, 'Admin.Advparameters.Feature') }}
    </a>
  {% endif %}

  <button type="submit" class="btn btn-primary">
    {{ 'Save'|trans({}, 'Admin.Actions') }}
  </button>
{% endblock %}
