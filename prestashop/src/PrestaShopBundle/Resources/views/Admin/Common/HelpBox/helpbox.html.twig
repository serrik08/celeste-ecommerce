 <span
   class="help-box{% if classes is defined %} {{ classes }}{% endif %}"
   data-toggle="popover"
   data-trigger="hover"
   data-html="true"
   {% if content is defined %}
     data-content="{{ content }}"
   {% endif %}

   {% if placement is defined %}
     data-placement="{{ placement }}"
   {% endif %}

   {% if title is defined %}
     data-title="{{ title }}"
   {% endif %}
 >
 </span>
