{% form_theme taxForm '@PrestaShop/Admin/TwigTemplateForm/prestashop_ui_kit.html.twig' %}

{{ form_start(taxForm) }}
<div class="card">
  <h3 class="card-header">
    {{ 'Tax'|trans({}, 'Admin.Global') }}
  </h3>

  <div class="card-body">
    <div class="form-wrapper">
      {{ form_errors(taxForm) }}
      {% block tax_form_widget %}
        {{ form_widget(taxForm) }}
      {% endblock %}
    </div>
  </div>

  <div class="card-footer">
    <div class="d-inline-flex">
      <a href="{{ path('admin_taxes_index') }}" class="btn btn-outline-secondary">
        {{ 'Cancel'|trans({}, 'Admin.Actions') }}
      </a>
    </div>
    <div class="d-inline-flex float-right">
      <button class="btn btn-primary" id="save-button">{{ 'Save'|trans({}, 'Admin.Actions') }}</button>
    </div>
  </div>

</div>
{{ form_end(taxForm) }}
