<tr class="column-headers {% if grid.attributes.is_empty_state %}d-none{% endif %}">
  {% for column in grid.columns %}
    <th
      scope="col"
      data-type="{{ column.type }}"
      data-column-id="{{ column.id }}"
      >
      {{ column_header(column, grid) }}
    </th>
  {% endfor %}
</tr>
