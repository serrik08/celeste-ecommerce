{% form_theme countryForm '@PrestaShop/Admin/TwigTemplateForm/prestashop_ui_kit.html.twig' %}

{{ form_start(countryForm) }}
  <div class="card">
    <h3 class="card-header">
      {{ 'Country'|trans({}, 'Admin.International.Feature') }}
    </h3>

    <div class="card-body">
      <div class="form-wrapper">
        {{ form_errors(countryForm) }}
        {% block form_country_widget %}
          {{ form_widget(countryForm) }}
        {% endblock %}
      </div>
    </div>

    <div class="card-footer">
      <div class="d-inline-flex">
        <a href="{{ path('admin_countries_index') }}" class="btn btn-outline-secondary">
          {{ 'Cancel'|trans({}, 'Admin.Actions') }}
        </a>
      </div>
      <div class="d-inline-flex float-right">
        <button class="btn btn-primary" id="save-button">{{ 'Save'|trans({}, 'Admin.Actions') }}</button>
      </div>
    </div>
  </div>
{{ form_end(countryForm) }}
