{% form_theme attributeForm '@PrestaShop/Admin/TwigTemplateForm/prestashop_ui_kit.html.twig' %}

{% block attribute_group_form_block %}
  {{ form_start(attributeForm) }}

  <div class="card">
    <h3 class="card-header">
      {{ 'Attribute value'|trans({}, 'Admin.Catalog.Attribute') }}
    </h3>

    <div class="card-body">
      <div class="form-wrapper">
        {{ form_widget(attributeForm) }}
      </div>
    </div>

    <div class="card-footer">
      <a href="{{ path('admin_attributes_index', {attributeGroupId: attributeGroupId}) }}"
         class="btn btn-outline-secondary">
        {{ 'Cancel'|trans({}, 'Admin.Actions') }}
      </a>
      <div class="float-right">
        <button type="submit" class="btn btn-primary" name="save-and-add-new">
          {{ 'Save then add another value'|trans({}, 'Admin.Catalog.Feature') }}
        </button>
        <button type="submit" class="btn btn-primary" id="save-button">
          {{ 'Save'|trans({}, 'Admin.Actions') }}
        </button>
      </div>
    </div>
  </div>

  {{ form_end(attributeForm) }}
{% endblock %}
