{% set legacyBaseLayout = lightDisplay|default(false) ? 'light_display_layout.tpl' : 'layout.tpl' %}
{% extends '@PrestaShop/Admin/layout.html.twig' %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('themes/new-theme/public/product' ~ rtl_suffix ~ '.css') }}" type="text/css" media="all">
{% endblock %}

{% block content %}
  {{ form_start(combinationForm, {attr: {class: 'form-horizontal combination-page', novalidate: 'novalidate'}}) }}
    {{ form_row(combinationForm) }}
  {{ form_end(combinationForm) }}
{% endblock %}

{% block javascripts %}
  {{ parent() }}

  <script src="{{ asset('themes/new-theme/public/combination_form.bundle.js') }}"></script>
{% endblock %}
