{% trans_default_domain 'Admin.Shopparameters.Feature' %}
{% form_theme seoOptionsForm '@PrestaShop/Admin/TwigTemplateForm/prestashop_ui_kit.html.twig' %}

{% block seo_options_configuration %}
  <div class="card">
    <h3 class="card-header">
      <i class="material-icons">settings</i> {{ 'SEO options'|trans }}
    </h3>
    <div class="card-body">
      <div class="form-wrapper">
        {{ form_widget(seoOptionsForm) }}
      </div>
    </div>
    <div class="card-footer">
      <div class="d-flex justify-content-end">
        <button class="btn btn-primary" id="meta_settings_seo_options_form_save_button">
          {{ 'Save'|trans({}, 'Admin.Actions') }}
        </button>
      </div>
    </div>
  </div>
{% endblock %}
