<div id="ps-quicknav-sidebar"  class="_fullspace">
    <div class="quicknav-header">
        <div class="float-left"><a href="#" data-toggle="sidebar" data-target=".sidebar">×</a></div>
        <h2>{{ title|raw_purified|trans({}, 'AdminCommon') }}</h2>
